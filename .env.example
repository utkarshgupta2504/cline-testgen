# ---- Copy to .env and adjust ----------------------------------------------
# The defaults target a LOCAL Ollama serving Gemma. Only CLINE_MODEL_ID usually
# needs changing (to match the tag you actually pulled — run `ollama list`).

# ---- LLM provider ----------------------------------------------------------
# Native SDK provider id: "ollama" (recommended for local). For a remote
# OpenAI-compatible endpoint (e.g. the future Gauss API) use "openai-compatible"
# and set CLINE_BASE_URL to the full ".../v1" URL.
CLINE_PROVIDER_ID=ollama

# The model tag as it appears in `ollama list`. NOTE: there is no public "Gemma 4";
# the 12B tag is usually gemma3:12b. Set this to whatever you pulled.
CLINE_MODEL_ID=gemma3:12b

# Ollama base URL. The native ollama provider handles /v1 + /api itself.
CLINE_BASE_URL=http://localhost:11434

# Ollama ignores this, but a non-empty value is safest.
CLINE_API_KEY=ollama

# ---- Agent guardrails ------------------------------------------------------
CLINE_MAX_ITERATIONS=12
CLINE_API_TIMEOUT_MS=180000

# ---- HTTP server (Phase 1c) ------------------------------------------------
HOST=127.0.0.1
PORT=8787

# ---- Logging ---------------------------------------------------------------
LOG_LEVEL=info      # debug | info | warn | error
LOG_DIR=logs
LOG_PRETTY=true     # false -> JSON-only console output
